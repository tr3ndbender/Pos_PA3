<Window x:Class="Ueben.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Ueben"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <StackPanel HorizontalAlignment="Center">
            <TextBox x:Name="inputTB">Input</TextBox>
            <Button x:Name="RateButton" Click="RateButton_Click" Height="100"></Button>
            <TextBlock x:Name="fromServerTB"></TextBlock>
        </StackPanel>
    </Grid>
</Window>
