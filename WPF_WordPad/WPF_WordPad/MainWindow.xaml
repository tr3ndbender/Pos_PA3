<Fluent:RibbonWindow x:Class="WPF_WordPad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:Fluent="urn:fluent-ribbon"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="WPF WordPad - Unbenannt" Height="650" Width="1000">

    <!-- Kommando-Bindungen für Datei-Aktionen -->
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.New"  Executed="NewCommand_Executed"/>
        <CommandBinding Command="ApplicationCommands.Open" Executed="OpenCommand_Executed"/>
        <CommandBinding Command="ApplicationCommands.Save" Executed="SaveCommand_Executed"/>
    </Window.CommandBindings>

    <DockPanel>

        <!-- ==================== RIBBON ==================== -->
        <Fluent:Ribbon DockPanel.Dock="Top">

            <!-- Datei-Menü (Backstage) -->
            <Fluent:Ribbon.Menu>
                <Fluent:Backstage>
                    <Fluent:BackstageTabControl>
                        <Fluent:Button Header="Neu"             Command="ApplicationCommands.New"/>
                        <Fluent:Button Header="Öffnen..."       Command="ApplicationCommands.Open"/>
                        <Fluent:Button Header="Speichern"       Command="ApplicationCommands.Save"/>
                        <Fluent:Button Header="Speichern unter..." Click="SaveAs_Click"/>
                        <Fluent:SeparatorTabItem/>
                        <Fluent:Button Header="Beenden"         Click="Exit_Click"/>
                    </Fluent:BackstageTabControl>
                </Fluent:Backstage>
            </Fluent:Ribbon.Menu>

            <!-- ======== Reiter: Start ======== -->
            <Fluent:RibbonTabItem Header="Start">

                <!-- Gruppe: Zwischenablage -->
                <Fluent:RibbonGroupBox Header="Zwischenablage">
                    <Fluent:Button Header="Einfügen"     Size="Large"
                                   Command="ApplicationCommands.Paste"
                                   CommandTarget="{Binding ElementName=richTextBox}"/>
                    <Fluent:Button Header="Ausschneiden" Size="Middle"
                                   Command="ApplicationCommands.Cut"
                                   CommandTarget="{Binding ElementName=richTextBox}"/>
                    <Fluent:Button Header="Kopieren"     Size="Middle"
                                   Command="ApplicationCommands.Copy"
                                   CommandTarget="{Binding ElementName=richTextBox}"/>
                </Fluent:RibbonGroupBox>

                <!-- Gruppe: Verlauf -->
                <Fluent:RibbonGroupBox Header="Verlauf">
                    <Fluent:Button Header="Rückgängig"  Size="Middle"
                                   Command="ApplicationCommands.Undo"
                                   CommandTarget="{Binding ElementName=richTextBox}"/>
                    <Fluent:Button Header="Wiederholen" Size="Middle"
                                   Command="ApplicationCommands.Redo"
                                   CommandTarget="{Binding ElementName=richTextBox}"/>
                </Fluent:RibbonGroupBox>

                <!-- Gruppe: Schrift -->
                <Fluent:RibbonGroupBox Header="Schrift">

                    <!-- Schriftart (ComboBox mit allen System-Schriften) -->
                    <ComboBox Name="fontFamilyCombo" Width="145" Height="24" Margin="2"
                              SelectionChanged="FontFamilyCombo_SelectionChanged"/>

                    <!-- Schriftgröße via Extended WPF Toolkit IntegerUpDown -->
                    <xctk:IntegerUpDown Name="fontSizeUpDown" Width="60" Height="24" Margin="2"
                                        Minimum="6" Maximum="200" Value="12"
                                        ValueChanged="FontSizeUpDown_ValueChanged"/>

                    <!-- Formatierungs-Buttons: Fett, Kursiv, Unterstrichen -->
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Fluent:ToggleButton Header="F" Width="28" Height="28" Margin="1"
                                             FontWeight="Bold" FontSize="13"
                                             Command="EditingCommands.ToggleBold"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="K" Width="28" Height="28" Margin="1"
                                             FontStyle="Italic" FontSize="13"
                                             Command="EditingCommands.ToggleItalic"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="U" Width="28" Height="28" Margin="1"
                                             FontSize="13"
                                             Command="EditingCommands.ToggleUnderline"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>

                    </StackPanel>

                    <!-- Schriftfarbe via Extended WPF Toolkit ColorPicker -->
                    <xctk:ColorPicker Name="colorPicker" Width="110" Height="24" Margin="2"
                                      SelectedColor="Black"
                                      SelectedColorChanged="ColorPicker_SelectedColorChanged"/>
                </Fluent:RibbonGroupBox>

                <!-- Gruppe: Absatz -->
                <Fluent:RibbonGroupBox Header="Absatz">

                    <!-- Listen -->
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Fluent:ToggleButton Header="• Liste"  Width="65" Height="28" Margin="1"
                                             Command="EditingCommands.ToggleBullets"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="1. Liste" Width="65" Height="28" Margin="1"
                                             Command="EditingCommands.ToggleNumbering"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                    </StackPanel>

                    <!-- Ausrichtung -->
                    <StackPanel Orientation="Horizontal" Margin="2">
                        <Fluent:ToggleButton Header="Links"   Width="50" Height="28" Margin="1"
                                             Command="EditingCommands.AlignLeft"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="Mitte"   Width="50" Height="28" Margin="1"
                                             Command="EditingCommands.AlignCenter"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="Rechts"  Width="50" Height="28" Margin="1"
                                             Command="EditingCommands.AlignRight"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                        <Fluent:ToggleButton Header="Block"   Width="50" Height="28" Margin="1"
                                             Command="EditingCommands.AlignJustify"
                                             CommandTarget="{Binding ElementName=richTextBox}"/>
                    </StackPanel>
                </Fluent:RibbonGroupBox>

            </Fluent:RibbonTabItem>
        </Fluent:Ribbon>

        <!-- ==================== STATUS BAR ==================== -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock Name="statusText" Text="Bereit"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ==================== RICH TEXT BOX ==================== -->
        <RichTextBox Name="richTextBox"
                     Style="{StaticResource RichTextBoxStyle}"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     SpellCheck.IsEnabled="True"
                     SelectionChanged="RichTextBox_SelectionChanged"/>

    </DockPanel>
</Fluent:RibbonWindow>
