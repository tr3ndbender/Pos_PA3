<Window x:Class="WPF_Wordle.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPF_Wordle"
        mc:Ignorable="d"
        Title="MainWindow" Height="520" Width="420">
    <Grid>
        <!-- 2 Spalten: Links Spiel, Rechts Statistik -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="StatsColumn" Width="0"/>
        </Grid.ColumnDefinitions>

        <!-- LINKE SEITE -->
        <StackPanel Grid.Column="0" Margin="10" HorizontalAlignment="Center">
            <TextBox x:Name="GuessInput" MaxLength="7" FontSize="20"
                     Width="200" Margin="0,10"/>
            <Button x:Name="RatenButton" Content="Raten" Click="RatenButton_Click"
                    Width="100" FontSize="16" Margin="0,5"/>

            <!-- Das Wordle Grid -->
            <ItemsControl x:Name="GuessGrid" Margin="0,15">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="6" Columns="7"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{Binding Color}"
                                Width="40" Height="40" Margin="2">
                            <TextBlock Text="{Binding Letter}"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="18" FontWeight="Bold"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- RECHTE SEITE: Statistik -->
        <StackPanel x:Name="StatsPanel" Grid.Column="1"
                    Visibility="Collapsed" Margin="20,10">
            <Label x:Name="WordLabel" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
            <Label x:Name="Stat1"/>
            <Label x:Name="Stat2"/>
            <Label x:Name="Stat3"/>
            <Label x:Name="Stat4"/>
            <Label x:Name="Stat5"/>
            <Label x:Name="Stat6"/>
            <Label x:Name="StatNever"/>
        </StackPanel>
    </Grid>
</Window>
