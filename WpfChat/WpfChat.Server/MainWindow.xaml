<Window x:Class="WpfChat.Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Chat – Server" Height="600" Width="800"
        Closing="Window_Closing">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <DockPanel Margin="8">
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
            <Label Content="Port:" VerticalAlignment="Center"/>
            <TextBox x:Name="TxtPort" Text="5000" Width="70" VerticalAlignment="Center"/>
            <Button x:Name="BtnStart" Content="▶ Starten" Click="BtnStart_Click"/>
            <Button x:Name="BtnStop" Content="⏹ Stoppen" Click="BtnStop_Click" IsEnabled="False"/>
            <Separator Margin="8,0"/>
            <Label x:Name="LblStatus" Content="Gestoppt" Foreground="Red" VerticalAlignment="Center" FontWeight="Bold"/>
        </StackPanel>

        <!-- Stats -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="TxtStats" Text="Verbundene Clients: 0"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Log -->
        <GroupBox Header="Server-Protokoll">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox x:Name="LstLog" Grid.Row="0"
                         FontFamily="Consolas" FontSize="12"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         VirtualizingPanel.IsVirtualizing="True"/>
                <Button Grid.Row="1" Content="Log leeren"
                        HorizontalAlignment="Right" Margin="0,4,0,0"
                        Click="BtnClearLog_Click"/>
            </Grid>
        </GroupBox>
    </DockPanel>
</Window>
