<Window x:Class="WpfChat.Client.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WPF Chat – Anmeldung" Height="400" Width="440"
        MinHeight="380" MinWidth="400"
        ResizeMode="CanResize" WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,0,0,8"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Height" Value="30"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
        <Style TargetType="Label">
            <Setter Property="Padding" Value="0,0,0,2"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <StackPanel Margin="24">
        <TextBlock Text="WPF Chat" FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center" Margin="0,0,0,16"
                   Foreground="#2c3e50"/>

        <Label Content="Server-IP:"/>
        <TextBox x:Name="TxtServerIp" Text="127.0.0.1"/>

        <Label Content="Port:"/>
        <TextBox x:Name="TxtPort" Text="5000"/>

        <Label Content="Benutzername:"/>
        <TextBox x:Name="TxtUsername"/>

        <Label Content="Passwort:"/>
        <PasswordBox x:Name="PbPassword"/>

        <TextBlock x:Name="TxtError" Foreground="Red" TextWrapping="Wrap"
                   Margin="0,0,0,8" Visibility="Collapsed"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="BtnLogin" Content="Anmelden" Width="120" Click="BtnLogin_Click"
                    Background="#2980b9" Foreground="White"/>
            <Button x:Name="BtnRegister" Content="Registrieren" Width="120" Click="BtnRegister_Click"
                    Background="#27ae60" Foreground="White"/>
        </StackPanel>
    </StackPanel>
</Window>
