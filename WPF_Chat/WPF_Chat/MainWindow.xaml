<Window x:Class="WPF_Chat.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
        Title="Chat" Height="600" Width="850"
        Closing="Window_Closing">

    <Window.Resources>
        <!--
            DataTemplate für Chat-Nachrichten.
            Ein DataTemplate beschreibt WIE ein Objekt (hier: ChatMessage) angezeigt wird.
            Es wird automatisch auf alle ChatMessage-Objekte in den ListBoxes angewendet.
            {Binding Username} bedeutet: zeige die Property "Username" des ChatMessage-Objekts.
        -->
        <DataTemplate x:Key="MessageTemplate">
            <StackPanel Orientation="Horizontal" Margin="2,4">
                <!-- Profilbild des Absenders (50x50 Pixel) -->
                <Image Width="40" Height="40"
                       Source="{Binding Image}"
                       Margin="0,0,8,0"
                       VerticalAlignment="Top"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <StackPanel>
                    <!-- Benutzername in der Farbe des Benutzers, fett gedruckt -->
                    <TextBlock Text="{Binding Username}"
                               FontWeight="Bold"
                               Foreground="{Binding Color}"/>
                    <!-- Nachrichtentext, bricht bei langen Texten um -->
                    <TextBlock Text="{Binding Text}"
                               TextWrapping="Wrap"
                               MaxWidth="500"/>
                </StackPanel>
            </StackPanel>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Zeile 0: Menüzeile -->
            <RowDefinition Height="*"/>    <!-- Zeile 1: Hauptinhalt -->
        </Grid.RowDefinitions>

        <!-- ===== MENÜZEILE ===== -->
        <Menu Grid.Row="0">
            <MenuItem Header="Profil">
                <!-- Klick öffnet einen FileDialog zum Bildauswählen -->
                <MenuItem Header="Bild auswählen" Click="SelectImageMenuItem_Click"/>
                <!-- Klick öffnet das Farb-Panel -->
                <MenuItem Header="Farbe auswählen" Click="SelectColorMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- ===== LOGIN PANEL =====
             Wird angezeigt solange der Benutzer nicht eingeloggt ist.
             Visibility="Visible" = sichtbar, "Collapsed" = unsichtbar und kein Platz -->
        <StackPanel x:Name="LoginPanel" Grid.Row="1"
                    VerticalAlignment="Center" HorizontalAlignment="Center" Width="300">
            <TextBlock Text="Chat Login" FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,20" HorizontalAlignment="Center"/>
            <TextBlock Text="Server IP:"/>
            <TextBox x:Name="ServerIpBox" Text="127.0.0.1" Margin="0,0,0,10"/>
            <TextBlock Text="Port:"/>
            <TextBox x:Name="ServerPortBox" Text="5000" Margin="0,0,0,10"/>
            <TextBlock Text="Benutzername:"/>
            <TextBox x:Name="UsernameBox" Margin="0,0,0,10"/>
            <TextBlock Text="Passwort:"/>
            <PasswordBox x:Name="PasswordBox" Margin="0,0,0,20"/>
            <Button Content="Anmelden" Click="LoginButton_Click" Margin="0,0,0,5"/>
            <Button Content="Registrieren" Click="RegisterButton_Click"/>
        </StackPanel>

        <!-- ===== CHAT PANEL =====
             Wird erst nach dem Login sichtbar gemacht. -->
        <Grid x:Name="ChatPanel" Grid.Row="1" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/> <!-- Linke Seite: Räume + Online-User -->
                <ColumnDefinition Width="*"/>   <!-- Rechte Seite: Chat -->
            </Grid.ColumnDefinitions>

            <!-- LINKE SEITE -->
            <Grid Grid.Column="0" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/> <!-- "Räume" Label -->
                    <RowDefinition Height="*"/>    <!-- Raumliste (nimmt verfügbaren Platz) -->
                    <RowDefinition Height="Auto"/> <!-- Buttons für Räume -->
                    <RowDefinition Height="Auto"/> <!-- "Online" Label -->
                    <RowDefinition Height="*"/>    <!-- Online-Benutzerliste -->
                    <RowDefinition Height="Auto"/> <!-- "Private Nachricht" Button -->
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Räume" FontWeight="Bold" Margin="0,0,0,3"/>

                <!-- Liste aller verfügbaren Räume -->
                <ListBox x:Name="RoomList" Grid.Row="1"
                         SelectionChanged="RoomList_SelectionChanged"/>

                <!-- Buttons zum Erstellen und Beitreten -->
                <StackPanel Grid.Row="2" Margin="0,3,0,8">
                    <TextBox x:Name="NewRoomBox" Margin="0,0,0,3"
                             ToolTip="Name des neuen Raums"/>
                    <Button Content="Raum erstellen" Click="CreateRoomButton_Click" Margin="0,0,0,3"/>
                    <Button Content="Raum beitreten" Click="JoinRoomButton_Click"/>
                </StackPanel>

                <TextBlock Grid.Row="3" Text="Online" FontWeight="Bold" Margin="0,0,0,3"/>

                <!-- Liste der aktuell eingeloggten Benutzer (ohne sich selbst) -->
                <ListBox x:Name="OnlineList" Grid.Row="4"/>

                <!-- Klick öffnet einen privaten Chat-Tab mit dem gewählten Benutzer -->
                <Button Grid.Row="5" Content="Private Nachricht"
                        Click="PrivateMessageButton_Click" Margin="0,3,0,0"/>
            </Grid>

            <!-- RECHTE SEITE: Tabs und Eingabefeld -->
            <Grid Grid.Column="1" Margin="5">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>    <!-- Tabs mit Nachrichten -->
                    <RowDefinition Height="Auto"/> <!-- Eingabezeile -->
                </Grid.RowDefinitions>

                <!-- Jeder Raum und jeder private Chat bekommt einen eigenen Tab -->
                <TabControl x:Name="RoomTabs" Grid.Row="0"/>

                <!-- Eingabezeile: Textfeld + Senden-Button -->
                <Grid Grid.Row="1" Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <!-- Enter-Taste sendet ebenfalls die Nachricht -->
                    <TextBox x:Name="MessageInput" Grid.Column="0" Margin="0,0,5,0"
                             KeyDown="MessageInput_KeyDown"/>
                    <Button Content="Senden" Grid.Column="1"
                            Click="SendButton_Click" Width="80"/>
                </Grid>
            </Grid>
        </Grid>

        <!-- ===== PROFIL-PANEL (Overlay für Farbauswahl) =====
             Wird über alles andere gelegt wenn der Benutzer "Farbe auswählen" klickt.
             Der dunkle Hintergrund (Background="#AA000000") macht den Rest unklickbar. -->
        <Grid x:Name="ProfilePanel" Grid.Row="1" Visibility="Collapsed"
              Background="#AA000000">
            <!-- Weißes Formular in der Mitte des Bildschirms -->
            <Border Background="White" Padding="20" CornerRadius="5"
                    Width="350" VerticalAlignment="Center" HorizontalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Farbe auswählen" FontWeight="Bold"
                               FontSize="16" Margin="0,0,0,15"/>

                    <!-- Extended WpfToolkit ColorPicker
                         ColorMode="ColorCanvas" zeigt die vollständige Farbpalette -->
                    <xctk:ColorPicker x:Name="ProfileColorPicker"
                                      Margin="0,0,0,15"
                                      ColorMode="ColorCanvas"/>

                    <!-- Vorschau: so sieht der Benutzername mit der gewählten Farbe aus -->
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                        <TextBlock Text="Vorschau: " VerticalAlignment="Center"/>
                        <TextBlock x:Name="ColorPreviewText" Text="Benutzername"
                                   FontWeight="Bold" VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </StackPanel>

                    <!-- Bestätigen oder Abbrechen -->
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Speichern" Click="SaveColorButton_Click"
                                Width="90" Margin="0,0,8,0"/>
                        <Button Content="Abbrechen" Click="CancelProfileButton_Click"
                                Width="90"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
