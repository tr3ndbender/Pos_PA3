<Window x:Class="WPF_Chat_Server.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Chat Server" Height="500" Width="400">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <Label Content="Port:"/>
            <TextBox x:Name="PortBox" Text="5000" Width="60" Margin="5,0"/>
            <Button Content="Starten" Click="StartButton_Click" Width="80"/>
        </StackPanel>

        <ListBox x:Name="LogList" Grid.Row="1"/>

        <StatusBar Grid.Row="2" Margin="0,10,0,0">
            <TextBlock x:Name="StatusText" Text="Gestoppt"/>
        </StatusBar>
    </Grid>
</Window>
