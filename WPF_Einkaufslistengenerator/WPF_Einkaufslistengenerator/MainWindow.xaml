<Window x:Class="WPF_Einkaufslistengenerator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Einkaufslisten-Generator" Height="550" Width="750"
        MinWidth="600" MinHeight="400">

    <DockPanel>

        <!-- ===== MENÜ ===== -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Datei">
                <MenuItem Header="Neu"        Command="{Binding NeuCommand}"/>
                <MenuItem Header="Laden..."   Command="{Binding LadenCommand}"/>
                <MenuItem Header="Speichern..." Command="{Binding SpeichernCommand}"/>
                <Separator/>
                <MenuItem Header="Drucken"    Command="{Binding DruckenCommand}"/>
            </MenuItem>
            <MenuItem Header="Bearbeiten">
                <MenuItem Header="Löschen (Auswahl)" Command="{Binding LoeschenCommand}"/>
            </MenuItem>
        </Menu>

        <!-- ===== HAUPTBEREICH: links Eingabe, rechts Liste ===== -->
        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ===== LINKE SEITE: Produktauswahl ===== -->
            <StackPanel Grid.Column="0" VerticalAlignment="Top" Margin="0,0,5,0">

                <TextBlock Text="Produktgruppe:" FontWeight="Bold" Margin="0,0,0,4"/>
                <!-- Combobox 1: Gruppen (Keys aus dem Dictionary) -->
                <ComboBox ItemsSource="{Binding Produktgruppen}"
                          SelectedItem="{Binding AusgewaehlteGruppe}"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Produkt aus Liste:" FontWeight="Bold" Margin="0,0,0,4"/>
                <!-- Combobox 2: Produkte der gewählten Gruppe -->
                <ComboBox ItemsSource="{Binding AktuelleProdukte}"
                          SelectedItem="{Binding AusgewaehltesProdukT}"
                          Margin="0,0,0,10"/>

                <TextBlock Text="Eigenes Produkt (nicht in Liste):" FontWeight="Bold" Margin="0,0,0,4"/>
                <!-- Textfeld für freie Eingabe -->
                <TextBox Text="{Binding EigenesProdukt, UpdateSourceTrigger=PropertyChanged}"
                         Margin="0,0,0,10"/>

                <TextBlock Text="Anzahl:" FontWeight="Bold" Margin="0,0,0,4"/>
                <!-- Slider und Textbox zeigen denselben Wert -->
                <Slider Minimum="1" Maximum="50"
                        Value="{Binding Anzahl}"
                        TickFrequency="1" IsSnapToTickEnabled="True"
                        Margin="0,0,0,4"/>
                <TextBox Text="{Binding Anzahl, UpdateSourceTrigger=PropertyChanged}"
                         Width="60" HorizontalAlignment="Left"
                         Margin="0,0,0,10"/>

                <Button Content="Hinzufügen"
                        Command="{Binding HinzufuegenCommand}"
                        Padding="10,5" HorizontalAlignment="Left"/>
            </StackPanel>

            <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Center"
                          VerticalAlignment="Stretch" ResizeBehavior="PreviousAndNext"/>

            <!-- ===== RECHTE SEITE: Einkaufsliste ===== -->
            <DockPanel Grid.Column="2">
                <TextBlock DockPanel.Dock="Top" Text="Einkaufsliste:"
                           FontWeight="Bold" Margin="5,0,0,4"/>

                <!-- SelectionMode=Extended → Mehrfachauswahl mit Shift/Strg für Löschen -->
                <ListBox ItemsSource="{Binding Einkaufsliste}"
                         SelectionMode="Extended"
                         x:Name="ListeBox"
                         Margin="5,0,0,0">
                    <!-- DataTemplate: wie ein Eintrag aussieht -->
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <TextBlock Text="{Binding Anzahl}"
                                           FontWeight="Bold" MinWidth="30"/>
                                <TextBlock Text=" x  " Foreground="Gray"/>
                                <TextBlock Text="{Binding Name}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
